# Database (Neon, Railway, or any Postgres)
DATABASE_URL="postgresql://user:password@host:5432/family_planner?schema=public"

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Required OAuth scope: https://www.googleapis.com/auth/calendar.readonly
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# App URL (required in production)
AUTH_URL="http://localhost:3000"

# Required on Vercel — trusts proxy host headers for NextAuth callbacks
AUTH_TRUST_HOST="true"
